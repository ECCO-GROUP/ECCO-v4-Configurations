frequency(106) = 2635200.0,
fields(1,106) = 'Vm_Advec',
filename(106) = 'diags/Vm_Advec_mon_mean/Vm_Advec_mon_mean',
#---
frequency(107) = 2635200.0,
fields(1,107) = 'Um_Diss',
filename(107) = 'diags/Um_Diss_mon_mean/Um_Diss_mon_mean',
#---
frequency(108) = 2635200.0,
fields(1,108) = 'Vm_Diss',
filename(108) = 'diags/Vm_Diss_mon_mean/Vm_Diss_mon_mean',
#---
frequency(109) = 2635200.0,
fields(1,109) = 'Um_Ext',
filename(109) = 'diags/Um_Ext_mon_mean/Um_Ext_mon_mean',
#---
frequency(110) = 2635200.0,
fields(1,110) = 'Vm_Ext',
filename(110) = 'diags/Vm_Ext_mon_mean/Vm_Ext_mon_mean',
#---
frequency(111) = 2635200.0,
fields(1,111) = 'AB_gU',
filename(111) = 'diags/AB_gU_mon_mean/AB_gU_mon_mean',
#---
frequency(112) = 2635200.0,
fields(1,112) = 'AB_gV',
filename(112) = 'diags/AB_gV_mon_mean/AB_gV_mon_mean',
#---
frequency(144) = 2635200.0,
fields(1,144) = 'Um_dPHdx',
filename(144) = 'diags/Um_dPHdx_mon_mean/Um_dPHdx_mon_mean',
