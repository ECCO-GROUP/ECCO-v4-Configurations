frequency(145) = 2635200.0,
fields(1,145) = 'Vm_dPHdy',
filename(145) = 'diags/Vm_dPHdy_mon_mean/Vm_dPHdy_mon_mean',
#---
frequency(148) = 2635200.0,
fields(1,148) = 'Um_Impl',
filename(148) = 'diags/Um_Impl_mon_mean/Um_Impl_mon_mean',
